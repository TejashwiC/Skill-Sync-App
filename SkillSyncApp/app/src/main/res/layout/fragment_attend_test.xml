<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <!-- Screen Header -->
    <TextView
        android:id="@+id/tvAttendTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Attend Skill Test"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- 1. Selection Mode Layout -->
    <FrameLayout
        android:id="@+id/layoutTestSelection"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvEmptyAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tests available. Follow peers to unlock their tests!"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:textStyle="italic"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAvailableTests"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- 2. Active MCQ Exam Mode Layout (hidden by default) -->
    <ScrollView
        android:id="@+id/layoutActiveExam"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Active Test Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvActiveTestTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kotlin Basics"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvActiveTestReward"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reward: 100 Credits"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Programmatic LinearLayout container for adding question cards -->
            <LinearLayout
                android:id="@+id/llActiveQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitExam"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Submit Answers"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
