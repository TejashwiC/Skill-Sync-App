<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="60dp">

    <TextView
        android:id="@+id/tvDayNumber"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="1"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/vDot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_dot_primary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvDayNumber"
        app:layout_constraintStart_toStartOf="@id/tvDayNumber"
        app:layout_constraintEnd_toEndOf="@id/tvDayNumber"
        android:layout_marginTop="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
