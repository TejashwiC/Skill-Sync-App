<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Profile Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Corner.Full"
                    android:background="@color/border"
                    android:scaleType="centerCrop" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabEditPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    app:fabCustomSize="32dp"
                    app:srcCompat="@android:drawable/ic_menu_camera"
                    app:tint="@color/white"
                    android:backgroundTint="@color/primary"
                    app:borderWidth="0dp"/>

                <ProgressBar
                    android:id="@+id/pbPhotoUpload"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_user_name"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_user_email"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Navigation Hub Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- View Profile option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavViewProfile"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_view_full"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Edit Profile option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavEditProfile"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_edit_details"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Skills Overview option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavSkillsOverview"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_skills_overview"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Add Skills option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavAddSkill"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_add_edit_skills"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- PDF Notes option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavNotes"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_shared_notes"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Settings option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavSettings"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_app_settings"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="24dp"/>

            <!-- Logout option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/profile_logout"
                app:backgroundTint="#EF4444"
                android:textColor="@color/white"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
