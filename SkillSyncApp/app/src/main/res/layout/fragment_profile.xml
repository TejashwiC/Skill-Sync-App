<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Profile Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfileAvatar"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@android:drawable/sym_def_app_icon"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Corner.Full"
                android:background="@color/border"
                android:layout_marginBottom="12dp"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Navigation Hub Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- View Profile option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavViewProfile"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="👁 View Full Profile"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Edit Profile option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavEditProfile"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="✏ Edit Profile Details"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Skills Overview option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavSkillsOverview"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="📚 My Skills Overview"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Add Skills option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavAddSkill"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="➕ Add/Edit Specific Skills"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- PDF Notes option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavNotes"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="📄 Shared PDF Notes / PDFs"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="12dp"/>

            <!-- Settings option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavSettings"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="⚙ Notification & App Settings"
                android:gravity="start|center_vertical"
                android:layout_marginBottom="24dp"/>

            <!-- Logout option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="🚪 Logout"
                app:backgroundTint="#EF4444"
                android:textColor="@color/white"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
