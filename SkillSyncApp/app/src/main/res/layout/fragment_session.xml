<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Peer Tutoring Sessions"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Quick Actions Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartHub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎥 Host Session"
            android:layout_marginRight="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinHub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔑 Join Session"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:weightSum="3">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLiveHub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🟢 Live"
            android:textSize="11sp"
            android:layout_marginRight="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistoryHub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 History"
            android:textSize="11sp"
            android:layout_marginRight="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFeedbackHub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⭐ Rate"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Active Session"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Active Session Card -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardActiveSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="#EF4444"
            app:strokeWidth="2dp"
            android:visibility="gone">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvActiveName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Kotlin Class"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#EF4444"
                        android:textColor="@color/white"
                        android:text="🔴 LIVE"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvActivePlatform"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Platform: Zoom"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <!-- Secret code sharing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F3F4F6"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECRET CODE FOR STUDENTS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActiveCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ABC123"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.3"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnJoinActive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open Meeting"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndActive"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="End Session"
                        android:textColor="#EF4444"
                        android:layout_marginLeft="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvNoActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No active tutoring session hosted by you."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:textStyle="italic"/>
    </FrameLayout>

</LinearLayout>
