<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAttemptTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAttemptPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#2E7D32"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAttemptScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Score: 10/10"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvAttemptCredits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+100 Credits earned"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvAttemptDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: Oct 26, 2026"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
