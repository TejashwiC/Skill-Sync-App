# SkillSync Selenium Test Environment Variables
# Copy this file to .env and fill in your Firebase test credentials

# Primary test account (used for all main tests)
TEST_EMAIL=your_test_email@example.com
TEST_PASSWORD=your_test_password

# Secondary test account (used for chat/follow tests)
TEST_EMAIL_2=your_second_test_email@example.com
TEST_PASSWORD_2=your_second_test_password

# Base URL of the locally served app (default: http://localhost:8080)
BASE_URL=http://localhost:8080

# Browser: chrome or firefox (default: chrome)
BROWSER=chrome

# Run headless browser: true or false (default: true for CI)
HEADLESS=true
